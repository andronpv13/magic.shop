# Подключение к SQL БД
DB_HOST=localhost   # ваш хост
DB_NAME=shop_db     # название БД
DB_USER=login       # ваше имя пользователя
DB_PASS=password    # ваш пароль
# Статус проекта (development(разработка)/production(продакшен))
APP_ENV=development
# Тайм-аут сессии в секундах
SESSION_LIFETIME=600
